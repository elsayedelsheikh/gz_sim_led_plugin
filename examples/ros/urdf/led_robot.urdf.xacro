<?xml version="1.0" ?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="led_robot">
  <xacro:include filename="$(find gz_led_plugin)/examples/ros/urdf/led_robot.gazebo.xacro" />

  <!-- Base link -->
  <link name="chassis_base">
    <inertial>
      <origin xyz="-0.151427 0 0.175" rpy="0 0 0"/>
      <mass value="1.14395"/>
      <inertia ixx="0.126164" ixy="0" ixz="0" iyy="0.416519" iyz="0" izz="0.481014"/>
    </inertial>
    <visual name="chassis_base_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="2.0 1 0.568726"/>
      </geometry>
      <material name="">
        <color rgba="0.5 0.5 1.0 1"/>
      </material>
    </visual>
    <collision name="chassis_base_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="2.0 1 0.568726"/>
      </geometry>
    </collision>
  </link>

  <!-- Top link -->
  <link name="chassis_top">
    <inertial>
      <origin xyz="-0.151427 0 0.484363" rpy="0 0 0"/>
      <mass value="1.14395"/>
      <inertia ixx="0.126164" ixy="0" ixz="0" iyy="0.416519" iyz="0" izz="0.481014"/>
    </inertial>
    <visual name="chassis_top_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.9 1 0.05"/>
      </geometry>
      <material name="">
        <color rgba="0.5 0.5 1.0 1"/>
      </material>
    </visual>
    <collision name="chassis_top_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.9 1 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Front LED -->
  <link name="front_led">
    <inertial>
      <origin xyz="-1.126427 0 0.484363" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual name="front_led_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 1 0.05"/>
      </geometry>
      <material name="">
        <color rgba="1.0 1.0 1.0 1"/>
      </material>
    </visual>
    <collision name="front_led_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 1 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Back LED -->
  <link name="back_led">
    <inertial>
      <origin xyz="0.823573 0 0.484363" rpy="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/>
    </inertial>
    <visual name="back_led_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 1 0.05"/>
      </geometry>
      <material name="">
        <color rgba="1.0 1.0 1.0 1"/>
      </material>
    </visual>
    <collision name="back_led_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 1 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Left wheel -->
  <link name="left_wheel">
    <inertial>
      <origin xyz="0.554283 0.625029 -0.025" rpy="-1.5707 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.145833" ixy="0" ixz="0" iyy="0.145833" iyz="0" izz="0.125"/>
    </inertial>
    <visual name="left_wheel_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.3"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision name="left_wheel_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.3"/>
      </geometry>
    </collision>
  </link>

  <!-- Right wheel -->
  <link name="right_wheel">
    <inertial>
      <origin xyz="0.554282 -0.625029 -0.025" rpy="-1.5707 0 0"/>
      <mass value="2"/>
      <inertia ixx="0.145833" ixy="0" ixz="0" iyy="0.145833" iyz="0" izz="0.125"/>
    </inertial>
    <visual name="right_wheel_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.3"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision name="right_wheel_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.3"/>
      </geometry>
    </collision>
  </link>

  <!-- Caster -->
  <link name="caster">
    <inertial>
      <origin xyz="-0.957138 0 -0.125" rpy="0 0 0"/>
      <mass value="1"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual name="caster_visual">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
      <material name="">
        <color rgba="0.2 0.2 0.2 1"/>
      </material>
    </visual>
    <collision name="caster_collision">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- Joints -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="chassis_base"/>
    <child link="left_wheel"/>
    <origin xyz="0.554283 0.625029 -0.025" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="-1.79769e+308" upper="1.79769e+308"/> -->
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="chassis_base"/>
    <child link="right_wheel"/>
    <origin xyz="0.554282 -0.625029 -0.025" rpy="-1.5707 0 0"/>
    <axis xyz="0 0 1"/>
    <!-- <limit lower="-1.79769e+308" upper="1.79769e+308"/> -->
  </joint>

  <joint name="base_to_top_joint" type="fixed">
    <parent link="chassis_base"/>
    <child link="chassis_top"/>
    <origin xyz="0 0 0.309363" rpy="0 0 0"/>
  </joint>

  <joint name="top_to_front_led_joint" type="fixed">
    <parent link="chassis_top"/>
    <child link="front_led"/>
    <origin xyz="-0.975 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="top_to_back_led_joint" type="fixed">
    <parent link="chassis_top"/>
    <child link="back_led"/>
    <origin xyz="0.975 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="caster_wheel_joint" type="fixed">
    <parent link="chassis_base"/>
    <child link="caster"/>
    <origin xyz="-0.805711 0 -0.3" rpy="0 0 0"/>
  </joint>
</robot>
